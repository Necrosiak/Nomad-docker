# =============================================================================
# NetworkMemories — Metal Gear Online 2 (nomad-docker)
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# NETWORK
# -----------------------------------------------------------------------------
# Public IP of your server (reachable by PS3/RPCS3 clients)
SERVER_IP=YOUR_SERVER_IP

# -----------------------------------------------------------------------------
# PORTS — Nomad Java server (Netty NIO)
# -----------------------------------------------------------------------------
MGO2_PORT_MAIN=10020        # Main auth/lobby entry point
MGO2_PORT_GAME=10100        # Game server
MGO2_PORT_RELAY1=10200      # UDP relay 1
MGO2_PORT_RELAY2=10201      # UDP relay 2

# -----------------------------------------------------------------------------
# DATABASE — MySQL / MariaDB
# The Nomad server calls a web API which in turn talks to the DB.
# The web API and Nomad server share the same database.
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=nomad
MYSQL_USER=YOUR_DB_USERNAME
MYSQL_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_HOST=nomad-mysql
MYSQL_PORT=3306

# -----------------------------------------------------------------------------
# WEB API — PHP (account creation, session management)
# Nomad calls this internally; PS3/RPCS3 web requests also go through here.
# Account creation endpoint: /account/create-mgo2
# -----------------------------------------------------------------------------
WEB_API_PORT=80
WEB_API_PORT_SSL=443
WEB_API_INTERNAL_URL=http://nomad-web/api

# Account constraints (hardcoded by MGO2 client — do NOT change):
#   Username: 8-32 chars, lowercase + digits only
#   Password: 4-16 digits only

# -----------------------------------------------------------------------------
# DNS — resolves MGO2 hostnames → SERVER_IP for PS3/RPCS3
# NOTE: DNS redirect alone is NOT sufficient for RPCS3.
# The SaveMGO plugin (plugin.sprx) hardcodes the server address.
# See docs/rpcs3-plugin-blocker.md for the full status.
# -----------------------------------------------------------------------------
DNS_PORT=53

# -----------------------------------------------------------------------------
# ADMIN PANEL
# -----------------------------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_SECRET=CHANGE_ME_RANDOM_SECRET_TOKEN

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
